<!DOCTYPE html>
<html lang="en">
<head>
<%- include('./partials/head') %>
<title>Sign Up — Blogify</title>
</head>
<body>
  <div class="page">

    <!-- Left branding panel -->
    <div class="left-panel">
      <div class="brand">
        <div class="brand-mark">
          <div class="brand-dot"></div>
          <span class="brand-name">Blogify</span>
        </div>
        <h4 class="left-heading">Write more.Worry less.<br>
<span>Blogify</span> handles everything. </h4>
        <p class="left-sub">Your voice deserves to be heard.
Start writing today and share your thoughts with readers who care.</p>
      </div>

      <div class="testimonial">
        <p>"Every great writer started somewhere.
Join a community of creators, thinkers, and storytellers."</p>
        <div class="t-author">
          <div class="t-avatar">PM</div>
          <div class="t-info">
            <span>Priti Maurya</span>
            <small>Head of Product, Arcflow</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Right form panel -->
    <div class="right-panel">
      <div class="form-box">
        <h1 class="form-title">Create account</h1>
        <p class="form-subtitle">Already have one? <a href="/user/login">login</a></p>

        <form action="/signup" method="POST" onsubmit="return validateForm()">

          <div class="field">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" placeholder="Please enter username" required />
          </div>

          <div class="field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="jane@company.com" required />
            <p class="hint">We'll never share your email with anyone else.</p>
          </div>

          <div class="field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="Min. 8 characters" required />
          </div>
          <button type="submit" class="btn-submit">Create my account</button>

        </form>

        <div class="divider">or continue with</div>

        <button class="oauth-btn" onclick="window.location.href='/auth/google'">
          <svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>

      </div>
    </div>

  </div>
  <%- include('./partials/scripts') %> 
</body>
</html>
